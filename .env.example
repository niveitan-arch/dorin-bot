# Telegram bot token from @BotFather (e.g. 123456789:ABCdef...)
TELEGRAM_BOT_TOKEN=

# Comma-separated numeric chat ids allowed to use the bot (e.g. 12345678,87654321)
ALLOWED_CHAT_IDS=

# How often (in minutes) the poller checks sources for new listings
POLL_INTERVAL_MIN=4

# On a brand-new search, how many of the currently-listed matches to send at once
# (newest in feed order). After that, only genuinely new listings are sent. 0 = none.
INITIAL_MATCHES_LIMIT=10

# Max time (ms) to wait for a Yad2 page to load before giving up on that URL.
# Lower = faster recovery from stuck/blocked loads (was effectively 45000).
YAD2_NAV_TIMEOUT_MS=20000

# How long (ms) to keep the headless browser warm between Yad2 operations before
# closing it. Keeps fetch->enrich fast within a poll cycle; closes when idle.
YAD2_IDLE_CLOSE_MS=90000
